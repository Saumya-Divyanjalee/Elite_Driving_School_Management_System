<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="768.0"
        prefWidth="1106.0"
        style="-fx-background-color: #f0f4f8;"
        xmlns="http://javafx.com/javafx/24.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="lk.ijse.orm.elite_driving_school_management_system.controller.StudentController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- TOP HEADER BAR -->
        <HBox prefHeight="64" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 30;">
            <VBox spacing="2">
                <Label text="Student Management" textFill="#0d47a1"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label text="Add, update and manage student records"
                       textFill="#90a4ae" style="-fx-font-size: 12px;" />
            </VBox>
        </HBox>

        <!-- BODY -->
        <VBox spacing="20" VBox.vgrow="ALWAYS"
              style="-fx-padding: 24 30 24 30;">

            <!-- FORM CARD -->
            <VBox spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eaf6; -fx-border-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <Label text="Student Information" textFill="#0d47a1"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <GridPane hgap="20" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120" halignment="RIGHT" />
                        <ColumnConstraints prefWidth="280" />
                        <ColumnConstraints prefWidth="120" halignment="RIGHT" />
                        <ColumnConstraints prefWidth="280" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints prefHeight="36" />
                        <RowConstraints prefHeight="36" />
                        <RowConstraints prefHeight="36" />
                        <RowConstraints prefHeight="36" />
                    </rowConstraints>

                    <!-- Row 0 -->
                    <Label text="Student ID:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtStudentId" editable="false" visible="false"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Name:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="txtName" promptText="Full name"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <!-- Row 1 -->
                    <Label text="Email:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="txtEmail" promptText="example@email.com"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Phone:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <TextField fx:id="txtPhone" promptText="07XXXXXXXX"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <!-- Row 2 -->
                    <Label text="Address:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtAddress" promptText="City, District"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Register Fee:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <TextField fx:id="txtRegisterFee" promptText="0.00"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="3" GridPane.rowIndex="2" />

                    <!-- Row 3 -->
                    <Label text="Reg. Date:" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <DatePicker fx:id="dateRegistration"
                                style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                                GridPane.columnIndex="1" GridPane.rowIndex="3" />
                </GridPane>

                <!-- ACTION BUTTONS -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="btnSave" text="💾  Save"
                            prefWidth="130" prefHeight="38"
                            onAction="#saveOnAction"
                            style="-fx-background-color: #1b5e20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnUpdate" text="✏️  Update"
                            prefWidth="130" prefHeight="38"
                            onAction="#updateOnAction"
                            style="-fx-background-color: #0d47a1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnDelete" text="🗑  Delete"
                            prefWidth="130" prefHeight="38"
                            onAction="#deleteOnAction"
                            style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnReset" text="↺  Reset"
                            prefWidth="130" prefHeight="38"
                            onAction="#resetOnAction"
                            style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                </HBox>
            </VBox>

            <!-- TABLE CARD -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eaf6; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <Label text="All Students" textFill="#0d47a1"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <TableView fx:id="tblStudents"
                           onMouseClicked="#clickOnAction"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="110" text="Student ID" />
                        <TableColumn fx:id="colName" prefWidth="160" text="Name" />
                        <TableColumn fx:id="colEmail" prefWidth="200" text="Email" />
                        <TableColumn fx:id="colPhone" prefWidth="120" text="Phone" />
                        <TableColumn fx:id="colAddress" prefWidth="160" text="Address" />
                        <TableColumn fx:id="colregisterfee" prefWidth="110" text="Reg. Fee" />
                        <TableColumn fx:id="colDate" prefWidth="140" text="Reg. Date" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>
