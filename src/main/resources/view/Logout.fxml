<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="768.0"
        prefWidth="1106.0"
        style="-fx-background-color: #f0f4f8;"
        xmlns="http://javafx.com/javafx/24.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="lk.ijse.orm.elite_driving_school_management_system.controller.LogoutController">

   <!-- Centered card -->
   <VBox
           layoutX="303" layoutY="184"
           prefWidth="500" prefHeight="400"
           alignment="CENTER"
           spacing="24"
           style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e8eaf6; -fx-border-radius: 16; -fx-padding: 48; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 16, 0, 0, 4);">

      <!-- Icon -->
      <AnchorPane prefWidth="80" prefHeight="80"
                  style="-fx-background-color: #fff3f3; -fx-background-radius: 40;">
         <Label layoutX="18" layoutY="14" text="🚪"
                style="-fx-font-size: 40px;" />
      </AnchorPane>

      <!-- Text -->
      <VBox spacing="8" alignment="CENTER">
         <Label text="Leaving So Soon?" textFill="#0d47a1"
                style="-fx-font-size: 24px; -fx-font-weight: bold;" />
         <Label text="Are you sure you want to log out?"
                textFill="#78909c" style="-fx-font-size: 14px;" />
         <Label text="All unsaved changes will be lost."
                textFill="#b0bec5" style="-fx-font-size: 12px;" />
      </VBox>

      <!-- Buttons -->
      <HBox spacing="16" alignment="CENTER">
         <Button fx:id="idCancel"
                 text="Stay Logged In"
                 prefWidth="180" prefHeight="44"
                 onAction="#cancelOnAction"
                 style="-fx-background-color: #e8eaf6; -fx-text-fill: #0d47a1; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
         <Button fx:id="idlogout"
                 text="Log Out"
                 prefWidth="180" prefHeight="44"
                 onAction="#logoutOnAction"
                 style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
      </HBox>
   </VBox>
</AnchorPane>
