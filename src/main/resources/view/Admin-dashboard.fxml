<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="768.0"
        prefWidth="1366.0"
        style="-fx-background-color: #0a0e1a;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="lk.ijse.orm.elite_driving_school_management_system.controller.AdminDashboard">

   <!-- SIDEBAR -->
   <VBox
           layoutX="0" layoutY="0"
           prefWidth="260" prefHeight="768"
           style="-fx-background-color: #0f1629;"
           AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
           spacing="0">

      <!-- Logo Area -->
      <HBox spacing="12" alignment="CENTER_LEFT"
            style="-fx-padding: 28 20 28 24; -fx-background-color: #0d47a1;">
         <ImageView fitHeight="42" fitWidth="42" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@../assets/logo.png" /></image>
         </ImageView>
         <VBox spacing="2">
            <Label text="ELITE" textFill="WHITE"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-letter-spacing: 4px;" />
            <Label text="DRIVING SCHOOL" textFill="#90caf9"
                   style="-fx-font-size: 9px; -fx-letter-spacing: 3px;" />
         </VBox>
      </HBox>

      <!-- Admin badge -->
      <HBox spacing="10" alignment="CENTER_LEFT"
            style="-fx-padding: 16 20 16 24; -fx-background-color: #13203a; -fx-border-color: #1a2a4a; -fx-border-width: 0 0 1 0;">
         <AnchorPane prefWidth="36" prefHeight="36"
                     style="-fx-background-color: #1e88e5; -fx-background-radius: 18;">
            <Label layoutX="10" layoutY="8" text="A" textFill="WHITE"
                   style="-fx-font-weight: bold; -fx-font-size: 16px;" />
         </AnchorPane>
         <VBox spacing="2">
            <Label text="Administrator" textFill="WHITE"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;" />
            <Label text="Full Access" textFill="#42a5f5"
                   style="-fx-font-size: 10px;" />
         </VBox>
      </HBox>

      <!-- Section label -->
      <Label text="MAIN MENU" textFill="#37474f"
             style="-fx-font-size: 9px; -fx-letter-spacing: 2px; -fx-padding: 20 0 8 24;" />

      <!-- Nav Buttons -->
      <Button fx:id="studentId" text="  👤  Student Management"
              prefWidth="260" prefHeight="46"
              onAction="#studentOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <Button fx:id="instructorId" text="  🎓  Instructor Management"
              prefWidth="260" prefHeight="46"
              onAction="#instructorOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <Button fx:id="courseId" text="  📚  Course Management"
              prefWidth="260" prefHeight="46"
              onAction="#courseOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <Button fx:id="lessonId" text="  📅  Lesson Scheduling"
              prefWidth="260" prefHeight="46"
              onAction="#lessonOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <Button fx:id="paymentId" text="  💳  Payment Management"
              prefWidth="260" prefHeight="46"
              onAction="#paymentOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <!-- Divider -->
      <Label text="ADMIN TOOLS" textFill="#37474f"
             style="-fx-font-size: 9px; -fx-letter-spacing: 2px; -fx-padding: 20 0 8 24;" />

      <Button fx:id="userId" text="  🔐  User Role Management"
              prefWidth="260" prefHeight="46"
              onAction="#userOnAction"
              style="-fx-background-color: transparent; -fx-text-fill: #b0bec5; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />

      <!-- Spacer -->
      <AnchorPane VBox.vgrow="ALWAYS" />

      <!-- Logout -->
      <Button fx:id="logoutId" text="  🚪  Log Out"
              prefWidth="260" prefHeight="50"
              onAction="#logoutOnAction"
              style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" />
   </VBox>

   <!-- MAIN CONTENT AREA -->
   <AnchorPane
           fx:id="ancMainContainer"
           layoutX="260" layoutY="0"
           style="-fx-background-color: #f0f4f8;"
           AnchorPane.topAnchor="0"
           AnchorPane.bottomAnchor="0"
           AnchorPane.leftAnchor="260"
           AnchorPane.rightAnchor="0" />

</AnchorPane>
