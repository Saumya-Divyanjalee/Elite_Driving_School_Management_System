<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
        prefHeight="768.0"
        prefWidth="1106.0"
        style="-fx-background-color: #f0f4f8;"
        xmlns="http://javafx.com/javafx/24.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="lk.ijse.orm.elite_driving_school_management_system.controller.LessonSchedulingController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- HEADER BAR -->
        <HBox prefHeight="64" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 30;">
            <VBox spacing="2">
                <Label text="Lesson Scheduling" textFill="#0d47a1"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label text="Schedule and manage driving lessons for students"
                       textFill="#90a4ae" style="-fx-font-size: 12px;" />
            </VBox>
        </HBox>

        <!-- BODY -->
        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 24 30 24 30;">

            <!-- FORM CARD -->
            <VBox spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eaf6; -fx-border-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <Label text="Lesson Information" textFill="#0d47a1"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <GridPane hgap="20" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="130" halignment="RIGHT" />
                        <ColumnConstraints prefWidth="250" />
                        <ColumnConstraints prefWidth="130" halignment="RIGHT" />
                        <ColumnConstraints prefWidth="250" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints prefHeight="38" />
                        <RowConstraints prefHeight="38" />
                        <RowConstraints prefHeight="38" />
                        <RowConstraints prefHeight="38" />
                    </rowConstraints>

                    <!-- Row 0 -->
                    <Label text="Lesson ID :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtLesson"
                               style="-fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Lesson Name :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="txtName" promptText="e.g. Car"
                               style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12;"
                               GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <!-- Row 1 -->
                    <Label text="Start Time :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cmbStartTime" prefWidth="250" prefHeight="36"
                              promptText="Select start time"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                              GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="End Time :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cmbEndTime" prefWidth="250" prefHeight="36"
                              promptText="Select end time"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                              GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <!-- Row 2 -->
                    <Label text="Date :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <DatePicker fx:id="datepicker" prefWidth="250" prefHeight="36"
                                style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                                GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Instructor :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <ComboBox fx:id="cmbInstructor" prefWidth="250" prefHeight="36"
                              promptText="Select instructor"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                              GridPane.columnIndex="3" GridPane.rowIndex="2" />

                    <!-- Row 3 -->
                    <Label text="Student :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox fx:id="cmbStudent" prefWidth="250" prefHeight="36"
                              promptText="Select student"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                              GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Course :" textFill="#546e7a"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           GridPane.columnIndex="2" GridPane.rowIndex="3" />
                    <ComboBox fx:id="cmbCourse" prefWidth="250" prefHeight="36"
                              promptText="Select course"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;"
                              GridPane.columnIndex="3" GridPane.rowIndex="3" />
                </GridPane>

                <!-- ACTION BUTTONS -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="btnSave" text="💾  Save"
                            prefWidth="130" prefHeight="38"
                            onAction="#saveOnAction"
                            style="-fx-background-color: #1b5e20; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnUpdate" text="✏️  Update"
                            prefWidth="130" prefHeight="38"
                            onAction="#updateOnAction"
                            style="-fx-background-color: #0d47a1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnDelete" text="🗑  Delete"
                            prefWidth="130" prefHeight="38"
                            onAction="#deleteOnAction"
                            style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="btnReset" text="↺  Reset"
                            prefWidth="130" prefHeight="38"
                            onAction="#resetOnAction"
                            style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" />
                </HBox>
            </VBox>

            <!-- TABLE CARD -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8eaf6; -fx-border-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                <Label text="All Scheduled Lessons" textFill="#0d47a1"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <TableView fx:id="tblLesson"
                           onMouseClicked="#onClickTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="collessonID"    prefWidth="90"  text="Lesson ID" />
                        <TableColumn fx:id="colName"        prefWidth="140" text="Name" />
                        <TableColumn fx:id="colStartTime"   prefWidth="110" text="Start Time" />
                        <TableColumn fx:id="colEndTime"     prefWidth="110" text="End Time" />
                        <TableColumn fx:id="colDate"        prefWidth="120" text="Date" />
                        <TableColumn fx:id="colInstructorID" prefWidth="120" text="Instructor" />
                        <TableColumn fx:id="colStudentID"   prefWidth="110" text="Student" />
                        <TableColumn fx:id="colCourseID"    prefWidth="110" text="Course" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>
